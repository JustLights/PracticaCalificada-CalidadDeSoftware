# ==============================================
# CREDENCIALES DE LA BASE DE DATOS
# (compose.yml lee estas variables)
# ==============================================
POSTGRES_USER=labuser
POSTGRES_PASSWORD=labpass
POSTGRES_DB=tasksdb
POSTGRES_TEST_DB=tasksdb_test

# ==============================================
# APLICACION
# ==============================================
PORT=3000

# ==============================================
# URLs DE CONEXION
# (para correr la app o los tests desde tu maquina local,
#  fuera de Docker; se construyen con las credenciales de arriba)
# ==============================================
DATABASE_URL=postgres://labuser:labpass@localhost:5432/tasksdb
TEST_DATABASE_URL=postgres://labuser:labpass@localhost:5433/tasksdb_test
BASE_URL=http://localhost:3000
